# Kopiraj u .env i popuni vrednosti. .env se NIKAD ne komituje.

# Baza podataka
DB_URL=jdbc:postgresql://localhost:55432/skolska_platforma
DB_USER=skolska
DB_PASS=skolska

# JWT — generisi novi tajni kljuc duzine bar 64 karaktera za produkciju
JWT_SECRET=promeni-ovaj-tajni-kljuc-najmanje-32-karaktera-dugacak!!
JWT_ACCESS_EXP=15
JWT_REFRESH_EXP=7

# SMTP — produkcioni nalog za slanje generisanih planova
#
# Gmail:        host=smtp.gmail.com,     port=587, auth=true, starttls=true
#   Lozinka MORA biti "App password" (ne licna gmail lozinka):
#   https://myaccount.google.com/apppasswords  (zahteva 2FA)
# Outlook 365:  host=smtp.office365.com, port=587, auth=true, starttls=true
# Mailtrap:     host=sandbox.smtp.mailtrap.io, port=2525, auth=true
# Mailpit (dev): host=localhost, port=1025, auth=false (bez user/pass)
#
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=noreply@skola.rs
MAIL_PASS=xxxxxxxxxxxxxxxx
MAIL_AUTH=true
MAIL_STARTTLS=true

# From adresa koju primalac vidi. Format moze biti:
#   "Skolska platforma <noreply@skola.rs>"
# ili samo adresa:
#   noreply@skola.rs
# Ako MAIL_FROM nije postavljen, koristi se MAIL_USER kao envelope sender.
MAIL_FROM=Skolska platforma <noreply@skola.rs>

# Storage za generisane Word/PDF fajlove
STORAGE_DIR=./storage

SERVER_PORT=8080
