# Kopiraj u .env i popuni vrednosti. .env se NIKAD ne komituje.

# Baza podataka
DB_URL=jdbc:postgresql://localhost:55432/skolska_platforma
DB_USER=skolska
DB_PASS=skolska

# JWT — generisi novi tajni kljuc duzine bar 64 karaktera za produkciju
JWT_SECRET=promeni-ovaj-tajni-kljuc-najmanje-32-karaktera-dugacak!!
JWT_ACCESS_EXP=15
JWT_REFRESH_EXP=7

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=planseduplan@gmail.com
MAIL_PASS=vule nzrq zdjo jfap
MAIL_AUTH=true
MAIL_STARTTLS=true
# Za Gmail/Office365: real SMTP handshake traje 5-15s. Default-ovi (15/30/15s)
# su dovoljni — overrider-uj samo ako imas spor link. Za Mailpit u dev-u ovo
# nije potrebno (timeout-i se ignorisu).
MAIL_SSL_TRUST=smtp.gmail.com
# MAIL_CONNECT_TIMEOUT=15000
# MAIL_TIMEOUT=30000
# MAIL_WRITE_TIMEOUT=15000
# From adresa.
# !!! VAZNO za Gmail: ako MAIL_FROM != MAIL_USER, Gmail ce mail prepustiti
# bez greske, ali primalac ce ga skoro sigurno tretirati kao SPAM (DKIM/SPF
# check ne prolazi za drugi domen). To je verovatno razlog ako mail "ode" iz
# logu ali ne stigne u Inbox primaoca.
#
# Pristup 1 — preporuceno za pocetak: From = isti kao MAIL_USER:
#   MAIL_FROM=EduPlan <planseduplan@gmail.com>
#   MAIL_REPLY_TO=noreplyplans@eduplan.rs   (odgovori idu ovde)
# Pristup 2 — produkcioni: kupi domen + Google Workspace ili SendGrid/Postmark
# sa konfigurisanim SPF/DKIM/DMARC zapisima za zeljeni domen.
MAIL_FROM=EduPlan <planseduplan@gmail.com>
MAIL_REPLY_TO=noreplyplans@eduplan.rs

# MAIL_DEBUG=true loguje ceo SMTP dialog (banner, EHLO, STARTTLS, login,
# DATA, server reply) u backend output. Korisno samo za debug — iskljuci
# u produkciji da ne curi user/pass u log.
# MAIL_DEBUG=false

STORAGE_DIR=./storage

SERVER_PORT=8080
